{
  "expo": {
    "name": "PRnote",
    "slug": "prnote",
    "scheme": "prnote",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "plugins": ["expo-router", "expo-sqlite"],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.prnote.app"
    },
    "ios": {
      "bundleIdentifier": "com.prnote.app"
    }
  }
}
